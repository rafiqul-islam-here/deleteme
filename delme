
name: Build & Push Docker Image

on:
  push:
    branches:
      - main

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      # 1. Checkout code
      - name: Checkout
        uses: actions/checkout@v4

      # 2. Login to Docker Hub
      - name: Login to DockerHub
        uses: docker/login-action@v3
        with:
          username: ${{ secrets.DOCKER_USERNAME }}
          password: ${{ secrets.DOCKER_TOKEN }}

      # 3. Build & Push Image
      - name: Build and Push to app-service-apps repo
        run: |
          docker build -t ${{ secrets.DOCKER_USERNAME }}/app-service-apps:${{ github.sha }} ./front-end
          docker tag ${{ secrets.DOCKER_USERNAME }}/app-service-apps:${{ github.sha }} ${{ secrets.DOCKER_USERNAME }}/app-service-apps:latest
          docker push ${{ secrets.DOCKER_USERNAME }}/app-service-apps:${{ github.sha }}
          docker push ${{ secrets.DOCKER_USERNAME }}/app-service-apps:latest